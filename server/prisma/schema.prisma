generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(STUDENT)
  name      String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  HEADMASTER
  TEACHER
  STUDENT
}

model Teacher {
  id         Int      @id @default(autoincrement())
  fullName   String
  employeeId String   @unique
  mobile     String
  email      String?
  subject    String
  username   String   @unique
  password   String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Student {
  id              Int      @id @default(autoincrement())
  admissionNumber String?  @unique
  fullName        String
  gender          String
  dateOfBirth     String?
  fatherName      String?
  motherName      String?
  mobile          String?
  address         String?
  className       String
  section         String   @default("A")
  rollNumber      String   @unique
  username        String?  @unique
  password        String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SchoolClass {
  id        Int      @id @default(autoincrement())
  name      String
  section   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, section])
}

model SchoolProfile {
  id             Int      @id @default(autoincrement())
  schoolName     String
  schoolCode     String
  district       String
  block          String
  academicYear   String
  headmasterName String
  updatedAt      DateTime @updatedAt
}

model Activity {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  createdAt DateTime @default(now())
}
