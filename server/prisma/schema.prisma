generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(STUDENT)
  name      String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  HEADMASTER
  TEACHER
  STUDENT
}

model Teacher {
  id         Int      @id @default(autoincrement())
  fullName   String
  employeeId String   @unique
  mobile     String
  email      String?
  subject    String
  username   String   @unique
  password   String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  timetable  Timetable[]
  homework   Homework[]
}

model Student {
  id              Int      @id @default(autoincrement())
  admissionNumber String?  @unique
  fullName        String
  gender          String
  dateOfBirth     String?
  fatherName      String?
  motherName      String?
  mobile          String?
  address         String?
  className       String
  section         String   @default("A")
  rollNumber      String   @unique
  username        String?  @unique
  password        String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendance   Attendance[]
  marks        Marks[]
  leaveRequests LeaveRequest[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  date      String
  status    String   // PRESENT, ABSENT, LATE
  className String
  section   String
  markedBy  Int?
  createdAt DateTime @default(now())

  @@unique([studentId, date])
}

model Marks {
  id            Int      @id @default(autoincrement())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     Int
  subject       String
  examName      String
  marksObtained Float
  totalMarks    Float
  grade         String?
  markedBy      Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subject, examName])
}

model Homework {
  id          Int      @id @default(autoincrement())
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   Int
  className   String
  section     String
  subject     String
  title       String
  description String?
  dueDate     String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveRequest {
  id             Int      @id @default(autoincrement())
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      Int
  fromDate       String
  toDate         String
  reason         String
  status         String   @default("PENDING")
  teacherComment String?
  reviewedBy     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Timetable {
  id        Int     @id @default(autoincrement())
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId Int
  className String
  section   String
  day       String
  period    Int
  subject   String
  startTime String
  endTime   String

  @@unique([className, section, day, period])
}

model SchoolClass {
  id        Int      @id @default(autoincrement())
  name      String
  section   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, section])
}

model SchoolProfile {
  id             Int      @id @default(autoincrement())
  schoolName     String
  schoolCode     String
  district       String
  block          String
  academicYear   String
  headmasterName String
  updatedAt      DateTime @updatedAt
}

model Activity {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  createdAt DateTime @default(now())
}
