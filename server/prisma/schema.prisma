generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(STUDENT)
  name      String?
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  HEADMASTER
  TEACHER
  STUDENT
}

model Teacher {
  id         Int      @id @default(autoincrement())
  fullName   String
  employeeId String   @unique
  mobile     String
  email      String?
  subject    String
  username   String   @unique
  password   String
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  timetable     Timetable[]
  homework      Homework[]
  ownedStudents Student[]     @relation("TeacherStudents")
  classes       SchoolClass[] @relation("ClassTeacher")
}

model Student {
  id              Int      @id @default(autoincrement())
  admissionNumber String?  @unique
  fullName        String
  gender          String
  dateOfBirth     String?
  fatherName      String?
  motherName      String?
  mobile          String?
  address         String?
  className       String
  section         String   @default("A")
  rollNumber      String   @unique
  username        String?  @unique
  password        String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdByTeacherId Int?
  createdByTeacher   Teacher?          @relation("TeacherStudents", fields: [createdByTeacherId], references: [id], onDelete: SetNull)
  attendance        Attendance[]
  marks             Marks[]
  leaveRequests     LeaveRequest[]
  governmentSchemes GovernmentScheme[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  date      String
  status    String   // PRESENT, ABSENT, LATE
  className String
  section   String
  markedBy  Int?
  createdAt DateTime @default(now())

  @@unique([studentId, date])
}

model Marks {
  id            Int      @id @default(autoincrement())
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId     Int
  subject       String
  examName      String
  marksObtained Float
  totalMarks    Float
  grade         String?
  markedBy      Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, subject, examName])
}

model Homework {
  id          Int      @id @default(autoincrement())
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   Int
  className   String
  section     String
  subject     String
  title       String
  description String?
  dueDate     String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveRequest {
  id             Int      @id @default(autoincrement())
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      Int
  fromDate       String
  toDate         String
  reason         String
  status         String   @default("PENDING")
  teacherComment String?
  reviewedBy     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Timetable {
  id         Int     @id @default(autoincrement())
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId  Int
  className  String
  section    String
  day        String
  period     Int
  subject    String
  roomNumber String  @default("")
  startTime  String
  endTime    String

  @@unique([className, section, day, period])
  @@unique([teacherId, day, period])
}

model SchoolClass {
  id             Int      @id @default(autoincrement())
  name           String
  section        String
  academicYear   String   @default("2025-2026")
  classTeacherId Int?
  classTeacher   Teacher? @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  roomNumber     String   @default("")
  maxStrength    Int      @default(40)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, section, academicYear])
}

model SchoolProfile {
  id             Int      @id @default(autoincrement())
  schoolName     String
  schoolCode     String
  emisCode       String   @default("")
  udiseCode      String   @default("")
  address        String   @default("")
  district       String
  block          String
  panchayat      String   @default("")
  pinCode        String   @default("")
  contactNumber  String   @default("")
  email          String   @default("")
  headmasterName String
  logoUrl        String   @default("")
  academicYear   String
  updatedAt      DateTime @updatedAt
}

model GovernmentScheme {
  id               Int      @id @default(autoincrement())
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId        Int
  className        String
  section          String
  academicYear     String
  schemeName       String
  distributionDate String   @default("")
  status           String   @default("PENDING")
  remarks          String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Activity {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  createdAt DateTime @default(now())
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipientId Int
  recipientRole String
  type        String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, recipientRole])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  message     String
  audience    String
  className   String?
  section     String?
  createdById Int
  createdByRole String
  createdByName String
  scheduledAt DateTime?
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  userName   String
  userRole   String
  action     String
  details    String?
  createdAt  DateTime @default(now())
}
